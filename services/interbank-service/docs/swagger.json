{
    "swagger": "2.0",
    "info": {
        "description": "Bank-to-bank coordination service implementing the inter-bank\ntransaction and OTC negotiation protocol. Authentication is\nper-peer via the X-Api-Key header (see §2.10).",
        "title": "Interbank Service API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/interbank": {
            "post": {
                "description": "Single ingress endpoint for the bank-to-bank protocol (§2.11).\nAccepts NEW_TX, COMMIT_TX and ROLLBACK_TX messages. The\nX-Api-Key header authenticates the sending bank.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "interbank"
                ],
                "summary": "Receive an inter-bank message",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Peer bank API key issued to the caller",
                        "name": "X-Api-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Message envelope (messageType + body)",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.MessageEnvelope"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "NEW_TX accepted with a vote",
                        "schema": {
                            "$ref": "#/definitions/dto.TransactionVote"
                        }
                    },
                    "202": {
                        "description": "Accepted, sender must retransmit later"
                    },
                    "204": {
                        "description": "Accepted, no response body"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    }
                }
            }
        },
        "/interbank/negotiations": {
            "post": {
                "description": "§3.2 — peer bank's buyer initiates a negotiation against\na seller in our bank. Returns the ForeignBankId of the\nnew negotiation owned by us.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "interbank-otc"
                ],
                "summary": "Create OTC negotiation (peer-initiated)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Peer bank API key",
                        "name": "X-Api-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Initial offer",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.OtcOffer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.ForeignBankId"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    }
                }
            }
        },
        "/interbank/negotiations/{rn}/{id}": {
            "get": {
                "description": "§3.4 — returns the current state of a negotiation owned by\nthis bank. The :rn path parameter must match this bank's\nrouting number.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "interbank-otc"
                ],
                "summary": "Get OTC negotiation",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Peer bank API key",
                        "name": "X-Api-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Routing number (this bank)",
                        "name": "rn",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Negotiation id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.OtcNegotiation"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    }
                }
            },
            "put": {
                "description": "§3.3 — peer bank posts a counter-offer against an ongoing\nnegotiation owned by us. Buyer/seller and ticker are\nimmutable; only negotiable parameters may change. The\nsame party may not counter twice in a row (turn rule).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "interbank-otc"
                ],
                "summary": "Post counter-offer",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Peer bank API key",
                        "name": "X-Api-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Routing number (this bank)",
                        "name": "rn",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Negotiation id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Updated offer",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.OtcOffer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "409": {
                        "description": "Turn violation or negotiation closed",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    }
                }
            },
            "delete": {
                "description": "§3.5 — either party may withdraw from a negotiation. The\noperation is idempotent: closing an already-closed\nnegotiation returns 204 without changing state.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "interbank-otc"
                ],
                "summary": "Close OTC negotiation",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Peer bank API key",
                        "name": "X-Api-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Routing number (this bank)",
                        "name": "rn",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Negotiation id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/errors.AppError"
                        }
                    }
                }
            }
        },
        "/interbank/negotiations/{rn}/{id}/accept": {
            "get": {
                "description": "§3.6 — STUB. Triggers a §2 NEW_TX with the 4 premium +\noption-pseudo postings. Implementation pending (depends\non §2 protocol layer).",
                "tags": [
                    "interbank-otc"
                ],
                "summary": "Accept OTC negotiation",
                "responses": {}
            }
        },
        "/interbank/public-stock": {
            "get": {
                "description": "§3.1 — STUB. Will be wired to trading-service for the list\nof stock holdings marked public for OTC by users in this bank.",
                "tags": [
                    "interbank-otc"
                ],
                "summary": "List public stocks",
                "responses": {}
            }
        },
        "/interbank/user/{rn}/{id}": {
            "get": {
                "description": "§3.7 — STUB. Will be wired to user-service.",
                "tags": [
                    "interbank-otc"
                ],
                "summary": "Resolve user display name",
                "responses": {}
            }
        }
    },
    "definitions": {
        "dto.Asset": {
            "type": "object",
            "required": [
                "asset",
                "type"
            ],
            "properties": {
                "asset": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "type": {
                    "enum": [
                        "MONAS",
                        "STOCK",
                        "OPTION"
                    ],
                    "allOf": [
                        {
                            "$ref": "#/definitions/dto.AssetType"
                        }
                    ]
                }
            }
        },
        "dto.AssetType": {
            "type": "string",
            "enum": [
                "MONAS",
                "STOCK",
                "OPTION"
            ],
            "x-enum-varnames": [
                "AssetMonas",
                "AssetStock",
                "AssetOption"
            ]
        },
        "dto.ForeignBankId": {
            "type": "object",
            "required": [
                "id",
                "routingNumber"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "maxLength": 64
                },
                "routingNumber": {
                    "type": "integer"
                }
            }
        },
        "dto.IdempotenceKey": {
            "type": "object",
            "required": [
                "locallyGeneratedKey",
                "routingNumber"
            ],
            "properties": {
                "locallyGeneratedKey": {
                    "type": "string",
                    "maxLength": 64
                },
                "routingNumber": {
                    "type": "integer"
                }
            }
        },
        "dto.MessageEnvelope": {
            "type": "object",
            "required": [
                "idempotenceKey",
                "messageType"
            ],
            "properties": {
                "idempotenceKey": {
                    "$ref": "#/definitions/dto.IdempotenceKey"
                },
                "messageType": {
                    "enum": [
                        "NEW_TX",
                        "COMMIT_TX",
                        "ROLLBACK_TX"
                    ],
                    "allOf": [
                        {
                            "$ref": "#/definitions/dto.MessageType"
                        }
                    ]
                }
            }
        },
        "dto.MessageType": {
            "type": "string",
            "enum": [
                "NEW_TX",
                "COMMIT_TX",
                "ROLLBACK_TX"
            ],
            "x-enum-varnames": [
                "MessageTypeNewTx",
                "MessageTypeCommitTx",
                "MessageTypeRollbackTx"
            ]
        },
        "dto.NoVoteReason": {
            "type": "object",
            "properties": {
                "posting": {
                    "$ref": "#/definitions/dto.Posting"
                },
                "reason": {
                    "$ref": "#/definitions/dto.NoVoteReasonKind"
                }
            }
        },
        "dto.NoVoteReasonKind": {
            "type": "string",
            "enum": [
                "UNBALANCED_TX",
                "NO_SUCH_ACCOUNT",
                "NO_SUCH_ASSET",
                "UNACCEPTABLE_ASSET",
                "INSUFFICIENT_ASSET",
                "OPTION_AMOUNT_INCORRECT",
                "OPTION_USED_OR_EXPIRED",
                "OPTION_NEGOTIATION_NOT_FOUND"
            ],
            "x-enum-varnames": [
                "ReasonUnbalancedTx",
                "ReasonNoSuchAccount",
                "ReasonNoSuchAsset",
                "ReasonUnacceptableAsset",
                "ReasonInsufficientAsset",
                "ReasonOptionAmountIncorrect",
                "ReasonOptionUsedOrExpired",
                "ReasonOptionNegotiationNotFound"
            ]
        },
        "dto.OtcNegotiation": {
            "type": "object",
            "properties": {
                "id": {
                    "$ref": "#/definitions/dto.ForeignBankId"
                },
                "offer": {
                    "$ref": "#/definitions/dto.OtcOffer"
                },
                "status": {
                    "description": "ongoing | accepted | cancelled | expired",
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        },
        "dto.OtcOffer": {
            "type": "object",
            "required": [
                "amount",
                "buyerId",
                "lastModifiedBy",
                "premium",
                "premiumCurrency",
                "priceCurrency",
                "pricePerStock",
                "sellerId",
                "settlementDate",
                "ticker"
            ],
            "properties": {
                "amount": {
                    "type": "integer",
                    "minimum": 1
                },
                "buyerId": {
                    "$ref": "#/definitions/dto.ForeignBankId"
                },
                "lastModifiedBy": {
                    "$ref": "#/definitions/dto.ForeignBankId"
                },
                "premium": {
                    "type": "number"
                },
                "premiumCurrency": {
                    "type": "string",
                    "maxLength": 8
                },
                "priceCurrency": {
                    "type": "string",
                    "maxLength": 8
                },
                "pricePerStock": {
                    "type": "number"
                },
                "sellerId": {
                    "$ref": "#/definitions/dto.ForeignBankId"
                },
                "settlementDate": {
                    "type": "string"
                },
                "ticker": {
                    "type": "string",
                    "maxLength": 16
                }
            }
        },
        "dto.Posting": {
            "type": "object",
            "required": [
                "account",
                "amount",
                "asset"
            ],
            "properties": {
                "account": {
                    "$ref": "#/definitions/dto.TxAccount"
                },
                "amount": {
                    "type": "number"
                },
                "asset": {
                    "$ref": "#/definitions/dto.Asset"
                }
            }
        },
        "dto.TransactionVote": {
            "type": "object",
            "properties": {
                "reasons": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.NoVoteReason"
                    }
                },
                "vote": {
                    "$ref": "#/definitions/dto.VoteKind"
                }
            }
        },
        "dto.TxAccount": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "id": {
                    "$ref": "#/definitions/dto.ForeignBankId"
                },
                "num": {
                    "type": "string"
                },
                "type": {
                    "enum": [
                        "PERSON",
                        "ACCOUNT",
                        "OPTION"
                    ],
                    "allOf": [
                        {
                            "$ref": "#/definitions/dto.TxAccountType"
                        }
                    ]
                }
            }
        },
        "dto.TxAccountType": {
            "type": "string",
            "enum": [
                "PERSON",
                "ACCOUNT",
                "OPTION"
            ],
            "x-enum-varnames": [
                "TxAccountPerson",
                "TxAccountAccount",
                "TxAccountOption"
            ]
        },
        "dto.VoteKind": {
            "type": "string",
            "enum": [
                "YES",
                "NO"
            ],
            "x-enum-varnames": [
                "VoteYes",
                "VoteNo"
            ]
        },
        "errors.AppError": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                }
            }
        }
    }
}